# Copy this to .env.local and fill in real values. Never commit .env.local.

# Claude API — https://platform.claude.com
ANTHROPIC_API_KEY=

# Adzuna job search API (free tier) — https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Country code for job searches: us, gb, in, au, ca...
ADZUNA_COUNTRY=us

# RapidAPI key for JSearch (free tier) — surfaces LinkedIn/Indeed/Glassdoor
# postings. Sign up at https://rapidapi.com and subscribe to "JSearch".
RAPIDAPI_KEY=

# ---- Accounts ------------------------------------------------------------
# Email + password sign-in is built in and always on — visitors create an
# account on the sign-in screen, no configuration needed.
#
# AUTH_SECRET signs the login sessions. Leave it blank and the app generates
# one on first run and writes it here automatically. Set your own to control
# it (generate with:  npx auth secret).
AUTH_SECRET=
#
# The providers below are OPTIONAL social logins ("Continue with Google"
# etc.) shown in addition to email/password. Each is free to create.
# Google — https://console.cloud.google.com/apis/credentials
# (OAuth client, redirect URI: <your-url>/api/auth/callback/google)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# GitHub — https://github.com/settings/developers
# (OAuth app, callback URL: <your-url>/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Microsoft (Outlook / work accounts) — https://entra.microsoft.com
# (App registration, redirect URI: <your-url>/api/auth/callback/microsoft-entra-id)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
